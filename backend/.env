# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in the values. NEVER commit .env to git.

# MongoDB
MONGODB_URI=mongodb+srv://ayanpal:shampapal@pgcluster.6ykspyc.mongodb.net/pg-meal-tracker

# JWT — Generate a strong secret: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=pgmaster_dev_secret_CHANGE_BEFORE_PRODUCTION_min_64_chars_long

# Session duration (e.g. 24h, 7d)
JWT_EXPIRES_IN=24h

# CORS — must match the frontend origin exactly
FRONTEND_URL=http://localhost:3000

# Port for the Express server
PORT=4000

# Node environment
NODE_ENV=development
